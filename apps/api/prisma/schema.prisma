generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  passwordHash String
  status UserStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id                 String   @id @default(cuid())
  name               String
  birthDate          DateTime?
  gender             String?
  occupation         String?
  phoneNumber        String?
  address            String?
  protectionCategory String?
  householdType      String?
  hasDisability      String?
  longTermCare       String?
  emergencyContact   String?
  housingType        String?
  housingOwnership   String?
  familyRelationship String?
  familyName         String?
  familyGender       String?
  familyBirthDate    DateTime?
  familyOccupation   String?
  familyCohabitation String?
  familyNotes        String?
  records            CounselingRecord[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model CounselingRecord {
  id                    String        @id @default(cuid())
  clientId              String
  client                Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title                 String
  sessionDate           DateTime
  sessionType           String
  sessionNumber         Int?
  presentingConcern     String
  sessionContent        String
  counselorObservation String?
  intervention          String?
  riskLevel             RiskLevel     @default(NONE)
  followUpPlan          String?
  summaryStatus         SummaryStatus @default(NOT_REQUESTED)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([clientId, sessionDate])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum RiskLevel {
  NONE
  ATTENTION
  URGENT
}

enum SummaryStatus {
  NOT_REQUESTED
  PENDING
  COMPLETED
}
